generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TradeStatus {
  pending
  confirmed
  cancelled
  expired
  completed
}

enum ImportStatus {
  pending
  downloaded
  uploaded
  approved
  rejected
  failed
}

enum SpawnType {
  auto
  manual
  admin
}

enum SpawnStatus {
  active
  captured
  expired
  cancelled
}

enum BoosterType {
  basic
  rare
  epic
}

enum BoosterTier {
  basic
  rare
  epic
  legendary
}

enum CardVariant {
  normal
  shiny
  holo
}

model User {
  id           String          @id @default(uuid())
  discordId    String          @unique
  username     String
  avatarUrl    String?
  isAdmin      Boolean         @default(false)
  level        Int             @default(1)
  xp           Int             @default(0)
  credits      Int             @default(0)
  fragments    Int             @default(0)
  lastManualSpawnAt DateTime?
  spawnCharges Int             @default(4)
  lastSpawnChargeRegenAt DateTime?
  lastDailyRewardAt DateTime?
  createdAt    DateTime        @default(now())
  inventory    InventoryItem[]
  fragmentBalances FragmentBalance[]
  boosters     Booster?
  userBoosters UserBooster[]
  captureLogs  CaptureLog[]
  spawnLogs    SpawnLog[]      @relation("SpawnRequestedBy")
  capturedSpawnLogs SpawnLog[] @relation("SpawnCapturedBy")
  spawnChargeLogs SpawnChargeLog[]
  transactionLogs TransactionLog[]
  economyLogs  EconomyLog[]
  collectionRewardClaims CollectionRewardClaim[]
  tradesAsOne  Trade[]         @relation("TradeUser1")
  tradesAsTwo  Trade[]         @relation("TradeUser2")
  tradeItems   TradeItem[]
  adminLogs    AdminLog[]
}

model Deck {
  id                     String                  @id @default(uuid())
  name                   String                  @unique
  cards                  Card[]
  collectionRewardClaims CollectionRewardClaim[]
}

model Rarity {
  id        String @id @default(uuid())
  name      String @unique
  weight    Int
  catchRate Float  @default(1.0)
  cards     Card[]
  fragmentBalances FragmentBalance[]
}

model FragmentBalance {
  id       String @id @default(uuid())
  userId   String
  rarityId String
  quantity Int    @default(0)
  user     User   @relation(fields: [userId], references: [id])
  rarity   Rarity @relation(fields: [rarityId], references: [id])

  @@unique([userId, rarityId])
  @@index([userId])
  @@index([rarityId])
}

model Card {
  id          String          @id @default(uuid())
  name        String          @unique
  deckId      String
  rarityId    String
  imageUrl    String?
  description String?
  acceptedNames Json?
  spawnEnabled Boolean         @default(true)
  blacklistReason String?
  releaseYear Int?
  rarityScore Int?
  rarityFactors Json?
  xpReward    Int
  dropRate    Float
  source      String?         @default("manual")
  sourceId    String?
  category    String?
  variant     String          @default("normal")
  deck        Deck            @relation(fields: [deckId], references: [id])
  rarity      Rarity          @relation(fields: [rarityId], references: [id])
  inventory   InventoryItem[]
  tradeItems  TradeItem[]
  captures    CaptureLog[]
  spawnLogs   SpawnLog[]

  @@index([source])
  @@index([sourceId])
  @@index([category])
}

model MovieImportBlacklist {
  id        String   @id @default(uuid())
  deck      String
  source    String
  sourceId  String   @unique
  displayName String
  reason    String
  payload   Json?
  createdAt DateTime @default(now())

  @@index([deck, reason])
  @@index([source])
}

model SpawnLog {
  id           String      @id @default(uuid())
  userId       String?
  spawnType    SpawnType
  cardId       String
  channelId    String
  status       SpawnStatus @default(active)
  createdAt    DateTime    @default(now())
  capturedAt   DateTime?
  capturedById String?
  requester    User?       @relation("SpawnRequestedBy", fields: [userId], references: [id])
  card         Card        @relation(fields: [cardId], references: [id])
  capturedBy   User?       @relation("SpawnCapturedBy", fields: [capturedById], references: [id])

  @@index([channelId, status])
  @@index([status])
  @@index([createdAt])
}

model SpawnChargeLog {
  id            String   @id @default(uuid())
  userId        String
  action        String
  amount        Int
  chargesBefore Int
  chargesAfter  Int
  createdAt     DateTime @default(now())
  user          User     @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
}

model InventoryItem {
  id       String @id @default(uuid())
  userId   String
  cardId   String
  variant  CardVariant @default(normal)
  quantity Int    @default(0)
  user     User   @relation(fields: [userId], references: [id])
  card     Card   @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@unique([userId, cardId, variant])
  @@index([userId, cardId])
}

model Booster {
  id       String @id @default(uuid())
  userId   String @unique
  quantity Int    @default(0)
  basicQuantity Int @default(0)
  rareQuantity Int @default(0)
  epicQuantity Int @default(0)
  user     User   @relation(fields: [userId], references: [id])
}

model UserBooster {
  id          String     @id @default(uuid())
  userId      String
  boosterType BoosterTier
  quantity    Int        @default(0)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  user        User       @relation(fields: [userId], references: [id])

  @@unique([userId, boosterType])
  @@index([userId])
}

model Trade {
  id           String      @id @default(uuid())
  user1Id      String
  user2Id      String
  user1Credits Int         @default(0)
  user2Credits Int         @default(0)
  status       TradeStatus @default(pending)
  expiresAt    DateTime
  user1Confirm Boolean     @default(false)
  user2Confirm Boolean     @default(false)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  user1        User        @relation("TradeUser1", fields: [user1Id], references: [id])
  user2        User        @relation("TradeUser2", fields: [user2Id], references: [id])
  items        TradeItem[]
}

model TradeItem {
  id       String @id @default(uuid())
  tradeId  String
  userId   String
  cardId   String?
  boosterType BoosterTier?
  variant  CardVariant @default(normal)
  quantity Int
  trade    Trade  @relation(fields: [tradeId], references: [id])
  user     User   @relation(fields: [userId], references: [id])
  card     Card?  @relation(fields: [cardId], references: [id], onDelete: Cascade)
}

model CaptureLog {
  id        String   @id @default(uuid())
  userId    String
  cardId    String
  channelId String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  card      Card     @relation(fields: [cardId], references: [id], onDelete: Cascade)
}

model AdminLog {
  id        String   @id @default(uuid())
  adminId   String?
  action    String
  target    String?
  metadata  Json?
  createdAt DateTime @default(now())
  admin     User?    @relation(fields: [adminId], references: [id])
}

model TransactionLog {
  id        String   @id @default(uuid())
  userId    String
  type      String
  amount    Int
  metadata  Json?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@index([type, createdAt])
}

model EconomyLog {
  id        String   @id @default(uuid())
  userId    String?
  type      String
  amount    Int?
  metadata  Json?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])

  @@index([type, createdAt])
  @@index([userId, createdAt])
}

model CollectionRewardClaim {
  id        String   @id @default(uuid())
  userId    String
  deckId    String
  milestone Int
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  deck      Deck     @relation(fields: [deckId], references: [id])

  @@unique([userId, deckId, milestone])
}

model ImageAsset {
  id          String   @id @default(uuid())
  key         String   @unique
  url         String
  sourceUrl   String?
  imageCredit String?
  createdAt   DateTime @default(now())
}

model ImportJob {
  id          String       @id @default(uuid())
  sourceUrl   String
  imageCredit String?
  status      ImportStatus @default(pending)
  imageAssetId String?
  error       String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model AppConfig {
  id             String @id @default("default")
  spawnIntervalS Int    @default(300)
  captureCooldownS Int  @default(5)
  spawnChannelId String?
  forceSpawnRequestedAt DateTime?
  forceSpawnCardId String?
  forceSpawnGuildId String?
  autoSpawnEnabled Boolean @default(true)
  autoSpawnIntervalMinutes Int @default(5)
  manualSpawnEnabled Boolean @default(true)
  manualSpawnCooldownMinutes Int @default(120)
  manualSpawnMaxCharges Int @default(4)
  manualSpawnRegenHours Int @default(6)
  commonSellPrice Int @default(10)
  uncommonSellPrice Int @default(20)
  rareSellPrice Int @default(50)
  veryRareSellPrice Int @default(100)
  importSellPrice Int @default(200)
  exoticSellPrice Int @default(500)
  blackMarketSellPrice Int @default(1500)
  commonRecyclePrice Int @default(5)
  uncommonRecyclePrice Int @default(10)
  rareRecyclePrice Int @default(25)
  veryRareRecyclePrice Int @default(50)
  importRecyclePrice Int @default(75)
  exoticRecyclePrice Int @default(100)
  blackMarketRecyclePrice Int @default(300)
  commonFragmentReward Int @default(1)
  uncommonFragmentReward Int @default(2)
  rareFragmentReward Int @default(5)
  veryRareFragmentReward Int @default(10)
  importFragmentReward Int @default(15)
  exoticFragmentReward Int @default(25)
  blackMarketFragmentReward Int @default(75)
  basicBoosterPrice Int @default(1000)
  rareBoosterPrice Int @default(3000)
  epicBoosterPrice Int @default(10000)
  legendaryBoosterPrice Int @default(30000)
  basicToRareJackpotRate Float @default(0.02)
  basicToEpicJackpotRate Float @default(0.005)
  basicToLegendaryJackpotRate Float @default(0.001)
  rareToEpicJackpotRate Float @default(0.03)
  rareToLegendaryJackpotRate Float @default(0.005)
  epicToLegendaryJackpotRate Float @default(0.02)
  normalVariantRate Float @default(0.94)
  shinyVariantRate Float @default(0.05)
  holoVariantRate Float @default(0.01)
  scarcityFloor Float @default(0.5)
  scarcityCap Float @default(3)
  fusionEnabled Boolean @default(true)
  boosterPrices Json?
  basePricesByRarity Json?
  jackpotRates Json?
  variantRates Json?
  craftBoosterFragmentCost Int @default(100)
  dailyCreditMin Int @default(50)
  dailyCreditMax Int @default(150)
  dailyBoosterChance Float @default(0.15)
}

model BotGuildConfig {
  guildId          String   @id
  guildName        String
  spawnChannelId   String?
  isActive         Boolean  @default(true)
  autoSpawnEnabled Boolean  @default(true)
  autoSpawnIntervalMinutes Int @default(5)
  allowedDecks     String[] @default([])
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}
