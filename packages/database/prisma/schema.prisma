generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TradeStatus {
  pending
  confirmed
  cancelled
  expired
  completed
}

enum ImportStatus {
  pending
  downloaded
  uploaded
  approved
  rejected
  failed
}

model User {
  id           String          @id @default(uuid())
  discordId    String          @unique
  username     String
  avatarUrl    String?
  isAdmin      Boolean         @default(false)
  level        Int             @default(1)
  xp           Int             @default(0)
  createdAt    DateTime        @default(now())
  inventory    InventoryItem[]
  boosters     Booster?
  captureLogs  CaptureLog[]
  tradesAsOne  Trade[]         @relation("TradeUser1")
  tradesAsTwo  Trade[]         @relation("TradeUser2")
  tradeItems   TradeItem[]
  adminLogs    AdminLog[]
}

model Deck {
  id    String @id @default(uuid())
  name  String @unique
  cards Card[]
}

model Rarity {
  id        String @id @default(uuid())
  name      String @unique
  weight    Int
  catchRate Float  @default(1.0)
  cards     Card[]
}

model Card {
  id          String          @id @default(uuid())
  name        String          @unique
  deckId      String
  rarityId    String
  imageUrl    String?
  description String?
  xpReward    Int
  dropRate    Float
  source      String?         @default("manual")
  sourceId    String?
  category    String?
  deck        Deck            @relation(fields: [deckId], references: [id])
  rarity      Rarity          @relation(fields: [rarityId], references: [id])
  inventory   InventoryItem[]
  tradeItems  TradeItem[]
  captures    CaptureLog[]

  @@index([source])
  @@index([sourceId])
  @@index([category])
}

model InventoryItem {
  id       String @id @default(uuid())
  userId   String
  cardId   String
  quantity Int    @default(0)
  user     User   @relation(fields: [userId], references: [id])
  card     Card   @relation(fields: [cardId], references: [id])

  @@unique([userId, cardId])
}

model Booster {
  id       String @id @default(uuid())
  userId   String @unique
  quantity Int    @default(0)
  user     User   @relation(fields: [userId], references: [id])
}

model Trade {
  id           String      @id @default(uuid())
  user1Id      String
  user2Id      String
  status       TradeStatus @default(pending)
  expiresAt    DateTime
  user1Confirm Boolean     @default(false)
  user2Confirm Boolean     @default(false)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  user1        User        @relation("TradeUser1", fields: [user1Id], references: [id])
  user2        User        @relation("TradeUser2", fields: [user2Id], references: [id])
  items        TradeItem[]
}

model TradeItem {
  id       String @id @default(uuid())
  tradeId  String
  userId   String
  cardId   String
  quantity Int
  trade    Trade  @relation(fields: [tradeId], references: [id])
  user     User   @relation(fields: [userId], references: [id])
  card     Card   @relation(fields: [cardId], references: [id])
}

model CaptureLog {
  id        String   @id @default(uuid())
  userId    String
  cardId    String
  channelId String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  card      Card     @relation(fields: [cardId], references: [id])
}

model AdminLog {
  id        String   @id @default(uuid())
  adminId   String?
  action    String
  target    String?
  metadata  Json?
  createdAt DateTime @default(now())
  admin     User?    @relation(fields: [adminId], references: [id])
}

model ImageAsset {
  id          String   @id @default(uuid())
  key         String   @unique
  url         String
  sourceUrl   String?
  imageCredit String?
  createdAt   DateTime @default(now())
}

model ImportJob {
  id          String       @id @default(uuid())
  sourceUrl   String
  imageCredit String?
  status      ImportStatus @default(pending)
  imageAssetId String?
  error       String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model AppConfig {
  id             String @id @default("default")
  spawnIntervalS Int    @default(300)
  captureCooldownS Int  @default(5)
  spawnChannelId String?
  forceSpawnRequestedAt DateTime?
  forceSpawnCardId String?
}
